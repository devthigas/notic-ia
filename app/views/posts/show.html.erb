<% content_for :title, "#{@post.title} | Notic-IA" %>

<article class="post-detail">
  <%= link_to posts_path, class: "post-back-link" do %>
    <span>←</span> Voltar para a página inicial
  <% end %>

  <header class="post-header">
    <span class="post-date">Publicado em <%= @post.created_at.strftime("%d/%m/%Y às %H:%M") %></span>
    <h1 class="post-title"><%= @post.title %></h1>
    <p class="post-description"><%= @post.description %></p>
  </header>

  <div class="post-body">
    <%= @post.body %>
  </div>

  <div class="post-actions">
    <%= link_to "Editar Notícia", edit_post_path(@post), class: "btn btn-secondary" %>
    <%= button_to "Excluir Notícia", @post, method: :delete, form: { data: { turbo_confirm: "Tem certeza que deseja excluir esta notícia permanentemente?" } }, class: "btn btn-danger" %>
  </div>
</article>
