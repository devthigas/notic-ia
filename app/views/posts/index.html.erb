<% content_for :title, "Notic-IA | Seu Portal de Notícias sobre IA" %>

<section class="hero">
  <h1>Notic.ia</h1>
  <p>Perspectivas, análises e crônicas semanais sobre a evolução da Inteligência Artificial.</p>
</section>

<section class="search-section">
  <%= form_with url: posts_path, method: :get, class: "search-form", local: true do |form| %>
    <%= form.text_field :query, 
                        value: params[:query], 
                        placeholder: "Buscar notícias pelo nome...", 
                        class: "search-input",
                        autocomplete: "off" %>
    <%= form.submit "Buscar", class: "search-button" %>
  <% end %>

  <% if params[:query].present? %>
    <%= link_to "← Limpar busca e ver todas", posts_path, class: "clear-search-link" %>
  <% end %>
</section>

<div class="posts-list" id="posts">
  <% if @posts.any? %>
    <%= render @posts %>
  <% else %>
    <div class="empty-state">
      <h3>Nenhuma postagem encontrada</h3>
      <% if params[:query].present? %>
        <p>Não encontramos resultados para a busca por "<strong><%= params[:query] %></strong>". Tente outros termos.</p>
        <%= link_to "Ver todas as postagens", posts_path, class: "btn btn-secondary" %>
      <% else %>
        <p>Ainda não há notícias cadastradas neste portal.</p>
        <%= link_to "Cadastrar primeira notícia", new_post_path, class: "btn btn-primary" %>
      <% end %>
    </div>
  <% end %>
</div>
