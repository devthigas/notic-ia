<div id="<%= dom_id post %>" class="post-card">
  <div class="card-header">
    <span class="card-meta">Notícia • <%= post.created_at.strftime("%d/%m/%Y") %></span>
    <h3 class="card-title"><%= post.title %></h3>
    <p class="card-description"><%= post.description %></p>
  </div>
  <div class="card-footer">
    <%= link_to post, class: "read-more" do %>
      Ler mais <span>→</span>
    <% end %>
    <div class="card-actions">
      <%= link_to edit_post_path(post), class: "btn-icon", title: "Editar" do %>
        ✏️
      <% end %>
      <%= button_to post, method: :delete, form: { data: { turbo_confirm: "Tem certeza que deseja excluir esta notícia?" } }, class: "btn-icon delete", title: "Excluir" do %>
        🗑️
      <% end %>
    </div>
  </div>
</div>
