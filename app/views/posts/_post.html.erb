<article id="<%= dom_id post %>" class="post-item">
  <header class="post-item-header">
    <div class="post-item-meta">
      <span class="post-item-date"><%= post.created_at.strftime("%d de %b, %Y") %></span>
    </div>
    <h2 class="post-item-title">
      <%= link_to post.title, post %>
    </h2>
  </header>
  <div class="post-item-content">
    <p class="post-item-description"><%= post.description %></p>
  </div>
  <footer class="post-item-footer">
    <%= link_to post, class: "post-item-read-more" do %>
      Ler artigo completo <span>→</span>
    <% end %>
    <div class="post-item-actions">
      <%= link_to "Editar", edit_post_path(post), class: "post-item-action-link" %>
      <span class="post-item-action-sep">•</span>
      <%= button_to "Excluir", post, method: :delete, form: { data: { turbo_confirm: "Tem certeza que deseja excluir esta notícia?" }, class: "post-item-action-form" }, class: "post-item-action-btn" %>
    </div>
  </footer>
</article>
