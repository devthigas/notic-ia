<% content_for :title, "Definir Nova Senha | Notic.ia" %>

<div class="form-card animate-fade-in" style="max-width: 480px; margin: 4rem auto;">
  <h1 class="form-title" style="margin-bottom: 1.5rem;">Definir nova senha</h1>

  <% if flash[:alert] %>
    <div class="error-summary" style="margin-bottom: 1.5rem;">
      <div class="error-title">Erro</div>
      <p style="font-size: 0.9rem; color: var(--text-secondary);"><%= flash[:alert] %></p>
    </div>
  <% end %>

  <%= form_with url: password_path(params[:token]), method: :put do |form| %>
    <div class="form-group">
      <%= form.label :password, "Nova Senha", class: "form-label" %>
      <%= form.password_field :password, 
                              required: true, 
                              autocomplete: "new-password", 
                              placeholder: "Mínimo 6 caracteres", 
                              maxlength: 72,
                              class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :password_confirmation, "Confirme a Nova Senha", class: "form-label" %>
      <%= form.password_field :password_confirmation, 
                              required: true, 
                              autocomplete: "new-password", 
                              placeholder: "Repita a nova senha", 
                              maxlength: 72,
                              class: "form-control" %>
    </div>

    <div class="form-actions" style="justify-content: flex-end; margin-top: 1.5rem; padding-top: 1rem;">
      <%= form.submit "Salvar senha", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
