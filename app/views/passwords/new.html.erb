<% content_for :title, "Recuperar Senha | Notic.ia" %>

<div class="form-card animate-fade-in" style="max-width: 480px; margin: 4rem auto;">
  <h1 class="form-title" style="margin-bottom: 1rem;">Recuperar senha</h1>
  <p style="color: var(--text-secondary); font-size: 0.95rem; text-align: center; margin-bottom: 2rem;">
    Insira seu endereço de e-mail e enviaremos as instruções para a redefinição de sua senha.
  </p>

  <% if flash[:alert] %>
    <div class="error-summary" style="margin-bottom: 1.5rem;">
      <div class="error-title">Erro</div>
      <p style="font-size: 0.9rem; color: var(--text-secondary);"><%= flash[:alert] %></p>
    </div>
  <% end %>

  <%= form_with url: passwords_path do |form| %>
    <div class="form-group">
      <%= form.label :email_address, "Endereço de E-mail", class: "form-label" %>
      <%= form.email_field :email_address, 
                           required: true, 
                           autofocus: true, 
                           autocomplete: "username", 
                           placeholder: "seu@email.com", 
                           value: params[:email_address],
                           class: "form-control" %>
    </div>

    <div class="form-actions" style="justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1rem;">
      <%= link_to "Voltar para o login", new_session_path, class: "post-item-action-link" %>
      <%= form.submit "Enviar instruções", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
